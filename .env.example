# GeoPulse M1 — copy to .env and fill in.

# markets-worker: free API key from https://twelvedata.com/pricing (free tier).
# Twelve Data is used because its free tier returns daily HISTORY (needed for the
# 90-day z-score baselines, so the globe shows real states on first run).
TWELVE_DATA_KEY=

# refresh cadences (seconds)
MARKETS_INTERVAL=300
GDELT_INTERVAL=900
SCORING_INTERVAL=300

# how much daily history to backfill from the markets provider
MARKETS_BACKFILL_DAYS=120

# --- M4 hardening ---
# Compose profiles (see docker-compose.yml):
#   lite (default): db + markets + gdelt + fx + scoring + api + frontend
#                   -> `podman compose up --build`   (~2 GB RAM)
#   full          : lite + macro-worker (World Bank)
#                   -> `podman compose --profile full up --build`
#
# Fault injection (test-only; leave empty in normal operation). Names a provider
# and a fault mode so workers degrade gracefully to stale — never crash / bad-write.
#   FAULT_INJECT="twelvedata=quota,worldbank=timeout,gdelt=malformed,er-api=quota"
FAULT_INJECT=
